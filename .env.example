# Copy to .env and fill in. Never commit .env.

NODE_ENV=production
PORT=3000

MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/riders?retryWrites=true

# Redis: use REDIS_URL for managed Redis, or host/port for self-hosted
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=7d

APP_NAME=RidersApp
# Public URL of this API (used in links / callbacks if needed)
BASE_URL=https://api.yourdomain.com
# Comma-separated origins allowed for CORS (Expo web, admin, etc.)
CORS_ORIGINS=https://yourdomain.com,http://localhost:8081

# Cloudflare R2 (S3-compatible)
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=

BASE_FARE=50
PRICE_PER_KM=20
MINIMUM_FARE=100

TEXTSMS_API_KEY=
TEXTSMS_PARTNER_ID=
TEXTSMS_SHORTCODE=
# TEXTSMS_FORCE=true
